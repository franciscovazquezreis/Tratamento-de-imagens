# GEMINI_API_KEY: Optional. Required for Gemini AI API calls if you want to use the server proxy mode.
# Se a chave estiver configurada aqui, a app arranca directamente e usa esta chave no servidor.
# Se a chave NÃO estiver configurada, a app pedirá ao utilizador para introduzir a sua própria chave (BYOK).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
